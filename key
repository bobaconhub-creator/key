-- KEY CHECK
-------------------------------------------------
local function processKey(key)

	-- Trim whitespace
	key = string.lower(string.gsub(key, "^%s+|%s+$", ""))

	if key == "hay" then

		saveData(KEY_FILE, key)

		loadstring(game:HttpGet(
		"https://raw.githubusercontent.com/bobaconhub-creator/Main/refs/heads/main/hayscript"
		))()

		gui:Destroy()
		return true

	elseif key == "bobaconhub" then

		saveData(KEY_FILE, key)

		loadstring(game:HttpGet(
		"https://raw.githubusercontent.com/doanhvu339-ux/baconpremium/refs/heads/main/inftro%20bobaconhub"
		))()

		gui:Destroy()
		return true

	elseif key == "vuhub2k12" then

		saveData(KEY_FILE, key)

		loadstring(game:HttpGet(
		"https://raw.githubusercontent.com/vukk2k12-hub/vukk/refs/heads/main/vukkhub"
		))()

		gui:Destroy()
		return true

	end

	return false

end

-------------------------------------------------
-- AUTO LOAD DEFAULT KEY
-------------------------------------------------
local function autoLoadDefault()

	local whitelistMode = tonumber(loadData(WHITELIST_FILE)) or -1

	if whitelistMode == 1 then
		-- Load babaconhub by default
		if processKey("bobaconhub") then return end

	elseif whitelistMode == -1 then
		-- Load hay by default
		if processKey("hay") then return end

	end

end

