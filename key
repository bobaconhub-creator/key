-------------------------------------------------
-- 📁 FILE SYSTEM
-------------------------------------------------
local KEY_FILE = "bacon_key.txt"
local WHITELIST_FILE = "bacon_whitelist.txt"

local function saveData(file, data)
	pcall(function()
		if writefile then
			writefile(file, data)
		end
	end)
end

local function loadData(file)
	local saved
	pcall(function()
		if readfile and isfile and isfile(file) then
			saved = readfile(file)
		end
	end)
	return saved
end

-------------------------------------------------
-- 👑 ROLE TAG
-------------------------------------------------
local function createTag(character,text,color)

	local head = character:WaitForChild("Head",5)
	if not head then return end

	if head:FindFirstChild("RoleTag") then
		head.RoleTag:Destroy()
	end

	local billboard = Instance.new("BillboardGui")
	billboard.Name = "RoleTag"
	billboard.Size = UDim2.new(0,100,0,22)
	billboard.StudsOffset = Vector3.new(0,2.5,0)
	billboard.AlwaysOnTop = true
	billboard.Parent = head

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1,0,1,0)
	label.BackgroundTransparency = 1
	label.Text = text
	label.TextColor3 = color
	label.TextStrokeTransparency = 0
	label.Font = Enum.Font.GothamBold
	label.TextSize = 12
	label.Parent = billboard

end

local function setupRole(player)

	if player.Name == OWNER_NAME then

		local function apply(char)
			createTag(char," ",Color3.fromRGB(255,215,0))
		end

		if player.Character then apply(player.Character) end
		player.CharacterAdded:Connect(apply)

	elseif DEPUTY_LIST[player.Name] then

		local function apply(char)
			createTag(char,"PHÓ SCRIPT",Color3.fromRGB(255,240,120))
		end

		if player.Character then apply(player.Character) end
		player.CharacterAdded:Connect(apply)

	end

end

for _,p in ipairs(Players:GetPlayers()) do
	setupRole(p)
end
Players.PlayerAdded:Connect(setupRole)

-------------------------------------------------
-- 💬 SEND CHAT
-------------------------------------------------
local function sendChat(msg)

	if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then

		local channel = TextChatService.TextChannels.RBXGeneral
		channel:SendAsync(msg)

	else

		ReplicatedStorage
		.DefaultChatSystemChatEvents
		.SayMessageRequest
		:FireServer(msg,"All")

	end

end

-------------------------------------------------
-- 🔐 WATCH OWNER COMMAND
-------------------------------------------------
local function watchOwner(player)

	if player.Name ~= OWNER_NAME then return end

	player.Chatted:Connect(function(message)

		-- /newkey 1 hay -1 name (playername)
		if string.lower(message):find("/newkey") then

			local parts = {}
			for part in string.gmatch(message, "%S+") do
				table.insert(parts, part)
			end

			-- /newkey, action, keytype, "name", playername
			if #parts >= 5 then

				local action = tonumber(parts[2]) -- 1 or -1
				local keyType = parts[3] -- hay, bobaconhub, vuhub2k12
				local nameArg = parts[4] -- "name"
				local playerName = parts[5] -- actual player name

				if nameArg == "name" and action and keyType then

					-- Check if player name matches
					if playerName == LocalPlayer.Name then

						-- Save the action to file: 1 = babaconhub default, -1 = hay default
						saveData(WHITELIST_FILE, tostring(action))
						sendChat("✅ Đã cập nhật whitelist cho " .. playerName .. " - Mode: " .. (action == 1 and "babaconhub" or "hay"))

					end

				end

			end

		end

	end)

end

for _,p in pairs(Players:GetPlayers()) do
	watchOwner(p)
end

Players.PlayerAdded:Connect(watchOwner)

